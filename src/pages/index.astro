---
import DefaultLayout from '@layouts/DefaultLayout.astro'
import Feature from '@components/Feature.astro'
import Counter from '@components/Counter.astro'
import ContentMedia from '@components/ContentMedia.astro'
import { Accordion, AccordionItem, Heading, Link } from 'accessible-astro-components'
import { Icon } from 'astro-icon/components'
---

<DefaultLayout
  title="CSRA Mesh — Meshtastic Community"
  description="A Meshtastic enthusiasts community in the Central Savannah River Area (CSRA). Building an off-grid mesh network across Augusta, Evans, Grovetown, North Augusta, Aiken, and beyond."
  useTitleTemplate={false}
>
  <!-- Hero -->
  <section class="hero my-24">
    <div class="container">
      <div class="grid grid-cols-1 items-center gap-24 lg:grid-cols-2">
        <div class="flex flex-col items-center gap-8 md:items-start">
          <h1 class="text-center text-6xl md:text-left lg:text-8xl">
            <span class="text-gradient">CSRA Mesh</span> Community
          </h1>
          <p class="text-2xl">
            A Meshtastic enthusiasts community in the Central Savannah River Area — connecting Augusta, Evans,
            Grovetown, North Augusta, Aiken, and beyond without internet or cell service.
          </p>
          <div class="flex flex-col gap-3 min-[500px]:flex-row">
            <Link
              href="https://discord.gg/mgzj2PmhKf"
              isButton
              type="primary"
              animateOnHover
              animationType="boop"
              isExternal
            >
              <Icon aria-hidden="true" name="lucide:message-circle" size="1.5rem" />
              Join our Discord
            </Link>
            <Link href="/faqs/quickstart" isButton type="secondary" animateOnHover animationType="boop">
              <Icon aria-hidden="true" name="lucide:book-open" size="1.5rem" />
              Getting Started
            </Link>
          </div>
        </div>
        <div class="hidden lg:block space-content">
          <p class="text-xl font-semibold">Active Nodes</p>
          <ul class="text-lg list-disc pl-6">
            <li><strong>Georgia:</strong> Evans, Grovetown, Augusta, Thomson</li>
            <li><strong>South Carolina:</strong> North Augusta, Clearwater, Aiken</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- What is CSRA Mesh -->
  <section class="my-64">
    <div class="container">
      <Heading level="h2" class="mb-8">What is the CSRA Mesh?</Heading>
      <div class="grid grid-cols-1 gap-12 md:grid-cols-2 lg:grid-cols-3">
        <Feature icon="lucide:radio" title="Off-Grid Communication">
          CSRA Mesh is a community bringing together communication enthusiasts from around the CSRA for coordination and
          collaboration — makers, Amateur Radio operators, GMRS operators, preppers, and more.
        </Feature>
        <Feature icon="lucide:wifi-off" title="No Infrastructure Needed">
          Using the LoRa protocol, inexpensive Meshtastic devices talk to each other and pass messages over moderate to
          long distances — without internet, cell service, or 3rd party infrastructure.
        </Feature>
        <Feature icon="lucide:sun" title="Solar-Powered Nodes">
          Nodes can be solar-powered and placed on rooftops to extend the mesh without power infrastructure. A small
          battery the size of two AA batteries can run a node for more than two weeks when fully charged.
        </Feature>
        <Feature icon="lucide:map-pin" title="Growing Coverage">
          We actively build out the mesh to connect the entire CSRA. Every new node extends overall reach and allows new
          areas to join the network.
        </Feature>
        <Feature icon="lucide:smartphone" title="Easy to Use">
          The Meshtastic app (iOS & Android) connects to your node via Bluetooth or WiFi to send and receive text
          messages — no technical expertise required.
        </Feature>
        <Feature icon="lucide:shield-check" title="Emergency Ready">
          After Hurricane Helene demonstrated the value of resilient communication, we've been building a network that
          works when traditional infrastructure fails.
        </Feature>
      </div>
    </div>
  </section>

  <!-- What is Meshtastic -->
  <ContentMedia imgSrc="/accessible-components.webp">
    <Heading level="h2">What is Meshtastic?</Heading>
    <p class="text-2xl">
      To quote the Meshtastic website: Meshtastic is "an open source, off-grid, decentralized, mesh network built to
      run on affordable, low-power devices." Visit{' '}
      <Link isExternal href="https://www.meshtastic.org">www.meshtastic.org</Link> to learn more.
    </p>
  </ContentMedia>

  <!-- What is a Node -->
  <ContentMedia imgSrc="/wcag-compliant.webp" reverseImg={true}>
    <Heading level="h2">What is a "Node"?</Heading>
    <p class="text-2xl">
      A node is a LoRa device flashed with Meshtastic firmware. They can be purchased pre-built, assembled from a kit,
      or home-built. Low-power units can run off a small solar panel placed on a rooftop — no power infrastructure
      required.
    </p>
  </ContentMedia>

  <!-- Stats -->
  <section class="mt-64 mb-32">
    <div class="container">
      <Heading level="h2" class="mb-16">CSRA Mesh by the Numbers</Heading>
      <div class="grid grid-cols-1 gap-12 sm:grid-cols-2 md:grid-cols-4">
        <Counter count="70+" title="Active Nodes" sub="And growing weekly" />
        <Counter count="6+" title="Cities" sub="Georgia & South Carolina" />
        <Counter count="5" title="Pages" sub="Of guides & resources" />
        <Counter count="86+" title="Members" sub="On Discord" />
      </div>
    </div>
  </section>

  <!-- FAQ Preview -->
  <section class="my-64">
    <div class="container grid grid-cols-1 gap-12 md:grid-cols-2">
      <div class="flex flex-col items-start gap-4">
        <Heading level="h2">Common Questions</Heading>
        <p class="text-2xl">
          New to Meshtastic or CSRA Mesh? We have guides covering initial setup, MQTT configuration, OTA firmware
          updates, and more.
        </p>
        <Link href="/faqs" isButton type="primary" animateOnHover animationType="boop">
          <Icon aria-hidden="true" name="lucide:book-open" size="1.5rem" />
          View all guides
        </Link>
      </div>
      <div class="space-content">
        <Accordion>
          <AccordionItem name="faq" title="How do I get started with Meshtastic?" open>
            <p>
              Purchase a LoRa node (many are available pre-built), install the Meshtastic app on your iOS or Android
              device, and follow our Quick Start Guide on the FAQs page. The key is making sure your node has an antenna
              attached before powering it on!
            </p>
          </AccordionItem>
          <AccordionItem name="faq" title="How can I join the CSRA Mesh network?">
            <p>
              Join us on Discord or Facebook and set up your node using our Quick Start Guide. The important settings
              are: region US, modem preset LONG_FAST, channel LongFast with PSK AQ==, and frequency override 906.875.
            </p>
          </AccordionItem>
          <AccordionItem name="faq" title="What if I don't see any other nodes?">
            <p>
              Leave your node running for roughly 24 hours and see what it connects to. If nothing shows, take it on a
              drive — there are currently good pockets of nodes in Evans Town Center and Grovetown off Exit 190.
            </p>
          </AccordionItem>
          <AccordionItem name="faq" title="Do I need a ham radio license?">
            <p>
              No license is required to use Meshtastic. The platform uses LoRa in the unlicensed ISM band. However, many
              of our members are also Amateur Radio operators who bring additional skills and knowledge to the community.
            </p>
          </AccordionItem>
        </Accordion>
      </div>
    </div>
  </section>

  <!-- Join Us -->
  <section class="my-64">
    <div class="space-content container text-center">
      <Heading level="h2">Want to Join Us?</Heading>
      <p class="text-2xl">
        Interested in communications? Like to create things? Have questions? Click a link below to join our Discord
        server or Facebook Group!
      </p>
      <div class="flex flex-col gap-3 min-[500px]:flex-row justify-center mt-8">
        <Link
          href="https://discord.gg/mgzj2PmhKf"
          isButton
          type="primary"
          animateOnHover
          animationType="boop"
          isExternal
        >
          <Icon aria-hidden="true" name="lucide:message-circle" size="1.5rem" />
          Join Discord
        </Link>
        <Link
          href="https://www.facebook.com/share/g/15wMGLcU8Q/"
          isButton
          type="secondary"
          animateOnHover
          animationType="boop"
          isExternal
        >
          <Icon aria-hidden="true" name="lucide:users" size="1.5rem" />
          Facebook Group
        </Link>
        <Link
          href="https://docs.google.com/forms/d/e/1FAIpQLSfg5NWMWLGjxHFxQfp-Yk0iuvJNppHfZZy4REmgHj2gQ0OTTw/viewform?usp=sharing"
          isButton
          type="secondary"
          animateOnHover
          animationType="boop"
          isExternal
        >
          <Icon aria-hidden="true" name="lucide:mail" size="1.5rem" />
          Contact Us
        </Link>
      </div>
    </div>
  </section>
</DefaultLayout>

<style lang="scss">
  .text-gradient {
    background: linear-gradient(
      315deg,
      light-dark(var(--color-primary-300), var(--color-secondary-100)) 25%,
      light-dark(var(--color-secondary-300), var(--color-primary-200))
    );
    background-clip: border-box;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
</style>
