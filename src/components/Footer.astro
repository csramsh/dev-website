---
import CallToAction from './CallToAction.astro'
import Logo from './Logo.astro'
import { Heading, Link } from 'accessible-astro-components'
import { siteUrl } from '@utils/url'

/**
 * Footer Component
 *
 * @description A component that displays the footer of the website
 */
const currentYear = new Date().getFullYear()
---

<footer>
  <CallToAction />
  <section class="py-20">
    <Heading level="h2" class="sr-only">Footer</Heading>
    <div class="container grid grid-cols-1 gap-8 md:grid-cols-3">
      <div class="flex flex-col gap-4">
        <Logo loading="lazy" />
        <p class="leading-[1.75]">
          A Meshtastic enthusiast community in the Central Savannah River Area — building an off-grid mesh network
          across Augusta, Evans, Grovetown, North Augusta, Aiken, and beyond.
        </p>
      </div>
      <div class="flex flex-col gap-4">
        <Heading level="h3" size="h6">Pages</Heading>
        <ul class="flex flex-col gap-2">
          <li><Link href={siteUrl('/')}>Home</Link></li>
          <li><Link href={siteUrl('/faqs')}>FAQs &amp; Guides</Link></li>
          <li><Link href={siteUrl('/emcomm')}>EmComm</Link></li>
          <li><Link href={siteUrl('/events')}>Events</Link></li>
          <li><Link href={siteUrl('/links')}>Links &amp; Resources</Link></li>
        </ul>
      </div>
      <div class="flex flex-col gap-4">
        <Heading level="h3" size="h6">Community</Heading>
        <ul class="flex flex-col gap-2">
          <li><Link isExternal href="https://discord.gg/mgzj2PmhKf">Discord Server</Link></li>
          <li><Link isExternal href="https://www.facebook.com/share/g/15wMGLcU8Q/">Facebook Group</Link></li>
          <li>
            <Link
              isExternal
              href="https://docs.google.com/forms/d/e/1FAIpQLSfg5NWMWLGjxHFxQfp-Yk0iuvJNppHfZZy4REmgHj2gQ0OTTw/viewform?usp=sharing"
              >Contact Us</Link
            >
          </li>
        </ul>
      </div>
    </div>
  </section>
  <section class="py-8">
    <div class="container">
      <p>&copy; {currentYear} CSRA Mesh Community. Not affiliated with or endorsed by the Meshtastic project.</p>
    </div>
  </section>
</footer>

<style>
  section {
    border-top: 1px solid var(--border-color-subtle);
  }
</style>
